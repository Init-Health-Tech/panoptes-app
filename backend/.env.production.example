# ─────────────────────────────────────────────────────────────────────────────
# MONOLITO en VM (RECOMENDADO): frontend + backend en el MISMO dominio.
# Sin CORS, sin cookies cross-subdominio. El login "just works".
# Copia este archivo a backend/.env en la VM y rellena los valores reales.
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=project_name.settings.production
SECRET_KEY=change-me-long-random

# docker-compose.prod.yml sobreescribe DATABASE_URL/REDIS/RABBIT con los servicios
# internos; conserva estos por claridad y para comandos manuales.
DATABASE_URL=postgres://panoptes:panoptes_change_me@db:5432/panoptes
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@broker:5672//
POSTGRES_PASSWORD=panoptes_change_me

# Dominio único que sirve TODO (SPA + API + admin).
ALLOWED_HOSTS=api.panoptes.init.com.mx
CSRF_TRUSTED_ORIGINS=https://api.panoptes.init.com.mx

# Mismo origen => cookies "Lax" (más seguro y sin necesidad de SameSite=None).
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# NO definas estas en monolito (déjalas vacías / comentadas):
#   FRONTEND_URL           -> vacío hace que el login redirija a "/" (el propio SPA)
#   CORS_ALLOWED_ORIGINS   -> no hay cross-origin
#   SESSION_COOKIE_DOMAIN  -> un solo host, no hace falta compartir cookie entre subdominios
#   CSRF_COOKIE_DOMAIN

SENDGRID_USERNAME=
SENDGRID_PASSWORD=
SENTRY_DSN=
ADMIN_ENVIRONMENT_LABEL=Production
ADMIN_ENVIRONMENT_COLOR=#ffffff
ADMIN_ENVIRONMENT_BACKGROUND_COLOR=#0f766e

# ─────────────────────────────────────────────────────────────────────────────
# ALTERNATIVA: deploy separado (Vercel FE + VM API en subdominios).
# Solo si de verdad quieres el front en Vercel. Requiere cookies cross-subdominio.
# Reemplaza el bloque de arriba (ALLOWED_HOSTS..CSRF_COOKIE_SAMESITE) por:
#
#   ALLOWED_HOSTS=api.avant.init.com.mx
#   FRONTEND_URL=https://avant.init.com.mx
#   CORS_ALLOWED_ORIGINS=https://avant.init.com.mx,https://panoptes-app.vercel.app
#   CSRF_TRUSTED_ORIGINS=https://avant.init.com.mx,https://panoptes-app.vercel.app
#   SESSION_COOKIE_DOMAIN=.init.com.mx
#   CSRF_COOKIE_DOMAIN=.init.com.mx
#   SESSION_COOKIE_SAMESITE=None
#   CSRF_COOKIE_SAMESITE=None
# ─────────────────────────────────────────────────────────────────────────────
