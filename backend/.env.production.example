DJANGO_SETTINGS_MODULE=project_name.settings.production
SECRET_KEY=change-me-long-random
# Si usas docker-compose.prod.yml, DATABASE_URL/REDIS/RABBIT se sobreescriben
# con los servicios internos; conserva estos por claridad o overrides locales.
DATABASE_URL=postgres://panoptes:panoptes_change_me@db:5432/panoptes
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@broker:5672//
POSTGRES_PASSWORD=panoptes_change_me

ALLOWED_HOSTS=api.avant.init.com.mx
FRONTEND_URL=https://avant.init.com.mx
CORS_ALLOWED_ORIGINS=https://avant.init.com.mx,https://panoptes-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://avant.init.com.mx,https://panoptes-app.vercel.app

# Shared parent domain so session/csrf cookies work across FE + API subdomains
SESSION_COOKIE_DOMAIN=.init.com.mx
CSRF_COOKIE_DOMAIN=.init.com.mx

SENDGRID_USERNAME=
SENDGRID_PASSWORD=
SENTRY_DSN=
ADMIN_ENVIRONMENT_LABEL=Production
ADMIN_ENVIRONMENT_COLOR=#ffffff
ADMIN_ENVIRONMENT_BACKGROUND_COLOR=#0f766e
